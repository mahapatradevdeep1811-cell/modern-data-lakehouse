# =============================================================================
# Modern Data Lakehouse — Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Warehouse toggle: "snowflake" or "bigquery"
# ---------------------------------------------------------------------------
WAREHOUSE_TARGET=snowflake

# ---------------------------------------------------------------------------
# Snowflake
# ---------------------------------------------------------------------------
SNOWFLAKE_ACCOUNT=your_account.region         # e.g. xy12345.us-east-1
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ROLE=SYSADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=LAKEHOUSE_DB
SNOWFLAKE_SCHEMA=CURATED

# ---------------------------------------------------------------------------
# Google BigQuery / GCP
# ---------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
BQ_DATASET=lakehouse_curated
BQ_LOCATION=US
BQ_TEMP_GCS_BUCKET=your-temp-bucket-name
BQ_MATERIALIZATION_DATASET=lakehouse_staging
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
AIRFLOW__CORE__FERNET_KEY=          # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__WEBSERVER__SECRET_KEY=     # Any random string

# ---------------------------------------------------------------------------
# Spark (override for cluster deployment)
# ---------------------------------------------------------------------------
SPARK_MASTER=local[*]               # e.g. spark://spark-master:7077 for cluster

# ---------------------------------------------------------------------------
# Notifications (optional)
# ---------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
ALERT_EMAIL=data-alerts@yourcompany.com
